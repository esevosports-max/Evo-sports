generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

generator clientDefault {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String                   @id @default(cuid())
  name           String?
  email          String?                  @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  roleId         String?
  phone          String?
  blocked        Boolean                  @default(false)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  blockedAt      DateTime?
  blockedBy      String?
  modifiedAt     DateTime?
  modifiedBy     String?
  modifiedFields String?
  club           Club?                    @relation("ClubPresident")
  clubRequest    ClubRegistrationRequest?
  notifications  Notification[]
  pushTokens     PushToken[]
  player         Player?
  staff          Staff?
  role           Role?                    @relation(fields: [roleId], references: [id])
}

model ClubRegistrationRequest {
  id              String   @id @default(cuid())
  userId          String   @unique
  clubName        String
  clubLogo        String?
  creationDate    DateTime
  address         String
  stadiumName     String
  pdfFilename     String?
  phone           String?
  status          String   @default("PENDING")
  rejectionReason String?
  chosenPlan      String   @default("Club")
  trialSelected   Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]
  permissions Permission[] @relation("PermissionToRole")
}

model Permission {
  id          String   @id @default(cuid())
  action      String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roles       Role[]   @relation("PermissionToRole")
}

model Club {
  id                    String               @id @default(cuid())
  name                  String
  logo                  String?
  creationDate          DateTime
  address               String
  stadiumName           String
  stadiumCapacity       String?
  phone                 String?
  presidentId           String?              @unique
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  subscriptionPlan      String?              @default("Standard")
  subscriptionStatus    String?              @default("Actif")
  subscriptionExpires   DateTime?
  subscriptionPaid      Boolean              @default(true)
  subscriptionMethod    String?              @default("Gratuit")
  subscriptionFeatures  Json?
  questionnaireTemplate Json?
  calendarEvents        CalendarEvent[]
  chatChannels          ChatChannel[]
  president             User?                @relation("ClubPresident", fields: [presidentId], references: [id], onDelete: Cascade)
  dailyQuestionnaires   DailyQuestionnaire[]
  players               Player[]
  polls                 Poll[]
  staff                 Staff[]
  categories            TeamCategory[]
}

model CalendarEvent {
  id           String          @id @default(cuid())
  clubId       String
  title        String
  type         String
  date         String
  time         String
  location     String
  details      String?
  creatorName  String?
  creatorRole  String?
  assignedTeam String?
  score        String?
  status       String          @default("PROGRAMME")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  club         Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  gpsData      PlayerGPSData[]
  telemetry    Telemetry[]
}

model TeamCategory {
  id                  String               @id @default(cuid())
  clubId              String
  name                String
  league              String
  coach               String
  maxPlayers          Int                  @default(0) @map("playersCount")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  composition         Composition?
  dailyQuestionnaires DailyQuestionnaire[]
  players             Player[]
  club                Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  staffMembers        Staff[]              @relation("StaffCategories")
}

model Staff {
  id               String         @id @default(cuid())
  userId           String         @unique
  clubId           String
  title            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  bloodGroup       String?
  allergies        String?
  lastCheckup      String?
  clearance        String?        @default("Autorisé")
  medicalNotes     String[]
  age              Int?
  nationality      String?
  birthDate        String?
  medicalTreatment String?
  medication       String?
  club             Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories       TeamCategory[] @relation("StaffCategories")
}

model Player {
  id               String          @id @default(cuid())
  userId           String          @unique
  clubId           String
  position         String?
  number           Int?
  teamCategoryId   String?
  age              Int?
  height           String?
  weight           String?
  foot             String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  isInjured        Boolean         @default(false)
  injuryType       String?
  injurySeverity   String?
  injuryDuration   String?
  injuryDate       DateTime?
  injuryReturn     DateTime?
  injuryStatus     String?
  injuryProgress   Int             @default(5)
  injuryDeclaredBy String?
  bloodGroup       String?
  allergies        String?
  lastCheckup      String?
  clearance        String?         @default("Autorisé")
  medicalNotes     String[]
  nationality      String?
  birthDate        String?
  medicalTreatment String?
  medication       String?
  dailyResponses   DailyResponse[]
  physicalIndices  PhysicalIndex[]
  physicalTests    PhysicalTest[]
  club             Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  teamCategory     TeamCategory?   @relation(fields: [teamCategoryId], references: [id])
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  gpsData          PlayerGPSData[]
  telemetry        Telemetry[]
  gpsDevice        GpsDevice?
}

model PhysicalIndex {
  id              String   @id @default(cuid())
  playerId        String
  questionnaireId String?
  sleepHours      Float?
  sleepQuality    Int?
  stress          Int?
  soreness        Int?
  fatigue         Int?
  rpe             Int?
  rpeDuration     Int?
  heartRate       Int?
  date            DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model Composition {
  id             String       @id @default(cuid())
  teamCategoryId String       @unique
  formation      Json
  slots          Json
  substitutes    Json
  isCommunicated Boolean      @default(false)
  communicatedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  teamCategory   TeamCategory @relation(fields: [teamCategoryId], references: [id], onDelete: Cascade)
}

model DailyQuestionnaire {
  id             String          @id @default(cuid())
  clubId         String
  teamCategoryId String?
  timeLimit      Int
  createdAt      DateTime        @default(now())
  scheduledFor   DateTime        @default(now())
  expiresAt      DateTime
  active         Boolean         @default(true)
  isApplied      Boolean         @default(false)
  questions      Json?
  club           Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  teamCategory   TeamCategory?   @relation(fields: [teamCategoryId], references: [id])
  responses      DailyResponse[]
}

model DailyResponse {
  id              String             @id @default(cuid())
  questionnaireId String
  playerId        String
  sleepQuality    Int
  fatigue         Int
  stress          Int
  soreness        Int
  heartRate       Int
  answers         Json?
  createdAt       DateTime           @default(now())
  player          Player             @relation(fields: [playerId], references: [id], onDelete: Cascade)
  questionnaire   DailyQuestionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)

  @@unique([questionnaireId, playerId])
}

model PhysicalTest {
  id        String   @id @default(cuid())
  playerId  String
  vma       Float
  vo2Max    Float
  sprint10m Float
  sprint30m Float
  cmj       Float
  sj        Float
  illinois  Float
  fat       Float
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model SerialCode {
  id           String   @id @default(cuid())
  code         String   @unique
  identifier   String   @unique
  plan         String
  duration     String
  used         Boolean  @default(false)
  usedByClubId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PaymentSubmission {
  id              String   @id @default(cuid())
  clubId          String
  clubName        String
  plan            String
  duration        String
  amount          Float
  method          String
  attachment      String?
  status          String   @default("PENDING")
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Poll {
  id            String       @id @default(cuid())
  clubId        String
  title         String
  description   String?
  type          String
  status        String       @default("ACTIVE")
  scheduledFor  DateTime?
  expiresAt     DateTime
  creatorId     String
  creatorName   String
  creatorRole   String?
  targetTeams   Json?
  targetRoles   Json?
  targetUserIds Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  club          Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  options       PollOption[]
  votes         PollVote[]
}

model PollOption {
  id        String     @id @default(cuid())
  pollId    String
  text      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes     PollVote[]
}

model PollVote {
  id         String     @id @default(cuid())
  pollId     String
  optionId   String
  userId     String
  userName   String
  choiceText String
  createdAt  DateTime   @default(now())
  option     PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  poll       Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
}

model ChatChannel {
  id               String        @id @default(cuid())
  clubId           String
  name             String
  description      String?
  isPrivate        Boolean       @default(false)
  isCustom         Boolean       @default(false)
  canReply         Boolean       @default(true)
  creatorId        String
  creatorName      String
  targetTeams      Json?
  targetRoles      Json?
  targetUserIds    Json?
  deletedByUserIds Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  club             Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  messages         ChatMessage[]
}

model ChatMessage {
  id               String            @id @default(cuid())
  channelId        String
  senderId         String
  senderName       String
  senderRole       String?
  senderClubName   String?
  senderClubLogo   String?
  content          String
  deletedByUserIds Json?
  createdAt        DateTime          @default(now())
  channel          ChatChannel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  views            ChatMessageView[]
}

model ChatMessageView {
  id        String      @id @default(cuid())
  messageId String
  userId    String
  userName  String
  userRole  String?
  viewedAt  DateTime    @default(now())
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model Announcement {
  id          String    @id @default(cuid())
  badgeText   String
  badgeStyle  String    @default("bg-blue-500/20 border-blue-500/35 text-blue-300 shadow-[0_0_10px_rgba(59,130,246,0.25)]")
  icon        String    @default("📢")
  title       String
  titleStyle  String    @default("from-emerald-400 to-teal-400")
  description String
  linkText    String    @default("En savoir plus")
  linkUrl     String    @default("/")
  mediaType   String    @default("image")
  mediaUrl    String
  active      Boolean   @default(true)
  type        String    @default("HOMEPAGE")
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SystemSetting {
  key       String   @id @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String    @default("INFO")
  read      Boolean   @default(false)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeletedAccount {
  id           String   @id @default(cuid())
  userId       String
  name         String
  email        String
  phone        String?
  roleTag      String
  clubId       String
  deletedBy    String
  deletedAt    DateTime @default(now())
  originalData String   // JSON stringified original account data
}

model AccountActionLog {
  id           String   @id @default(cuid())
  actionType   String
  targetName   String
  targetRole   String
  operatorName String
  operatorRole String
  clubId       String
  createdAt    DateTime @default(now())
}

model PlayerGPSData {
  id                    String        @id @default(cuid())
  playerId              String
  eventId               String?
  date                  DateTime
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  // 1. Physical Telemetry
  distanceTotal         Float         @default(0.0)
  hsrDistance           Float         @default(0.0)
  sprintDistance        Float         @default(0.0)
  accelerations         Int           @default(0)
  decelerations         Int           @default(0)
  vMax                  Float         @default(0.0)
  avgHeartRate          Int           @default(0)
  peakHeartRate         Int           @default(0)
  redZoneTime           Int           @default(0)

  // 2. Technical Metrics
  xG                    Float         @default(0.0)
  xA                    Float         @default(0.0)
  progressivePasses     Int           @default(0)
  successUnderPressure  Float         @default(0.0)
  duelsWon              Int           @default(0)
  turnovers             Int           @default(0)
  recoveries            Int           @default(0)

  // 3. Tactical & Positioning
  ppda                  Float         @default(0.0)
  compacity             Float         @default(0.0)
  reactionTime          Float         @default(0.0)
  heatmapX              Float         @default(0.0)
  heatmapY              Float         @default(0.0)

  // 4. Workload & Injury Prevention
  acwr                  Float         @default(1.0)
  asymmetry             Float         @default(0.0)
  neuromuscularFatigue  Float         @default(0.0)

  player                Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)
  event                 CalendarEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

model GpsDevice {
  id        String   @id
  playerId  String?  @unique
  battery   Int      @default(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  player    Player?  @relation(fields: [playerId], references: [id], onDelete: SetNull)
}

model Telemetry {
  id        String        @id @default(cuid())
  playerId  String
  eventId   String?
  x         Float
  y         Float
  speed     Float         @default(0.0)
  heartRate Int?
  timestamp DateTime      @default(now())
  player    Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)
  event     CalendarEvent? @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model PaymentConfig {
  id        String   @id @default("default")
  rib       String   @default("007 99999 0000123456 78")
  cle       String   @default("78")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PushToken {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  deviceType String?  @default("android")
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SubscriptionPlan {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String?
  type            String   // "GRATUIT" or "PAYANT"
  
  // Free plan duration details (years, months, days, hours, minutes, seconds)
  durationYears   Int      @default(0)
  durationMonths  Int      @default(0)
  durationDays    Int      @default(0)
  durationHours   Int      @default(0)
  durationMinutes Int      @default(0)
  durationSeconds Int      @default(0)
  
  // Paid plans billing choices: "BOTH" (both), "MONTHLY" (monthly only), "ANNUAL" (annual only)
  billingPeriodType String @default("BOTH")
  priceMonthly    Float    @default(0.0)
  priceYearly     Float    @default(0.0)
  
  // Payment methods: comma separated values
  paymentMethods  String   @default("CCP, BaridiMob, Virement")
  
  // Limits
  maxTeams        Int      @default(-1) // -1 for unlimited
  
  // Staff limits (JSON representation like { "ENTRAINEUR_PRINCIPAL": 1, "MEDECIN": 1 } etc.)
  staffLimits     Json?
  
  // Club options / features (checklist of true/false choices)
  hasDashboard    Boolean  @default(true)
  hasPayment      Boolean  @default(true)
  hasPlanning     Boolean  @default(true)
  hasMessaging    Boolean  @default(true)
  hasPolls        Boolean  @default(true)
  hasStructure    Boolean  @default(true)
  hasStaff        Boolean  @default(true)
  hasPlayers      Boolean  @default(true)
  hasTactical     Boolean  @default(true)
  hasTrainings    Boolean  @default(true)
  hasMatches      Boolean  @default(true)
  hasInjuries     Boolean  @default(true)
  hasMedical      Boolean  @default(true)
  hasTests        Boolean  @default(true)
  hasWelfare      Boolean  @default(true)
  hasGPS          Boolean  @default(false)
  hasRbac         Boolean  @default(true)
  hasSupport      Boolean  @default(true)
  
  // Custom features list (JSON array of strings)
  featuresList    Json?
  
  // Styling / Presentation for pricing page
  popular         Boolean  @default(false)
  colorTheme      String   @default("sky") // "sky", "indigo", "emerald", "amber", "rose", etc.
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}



